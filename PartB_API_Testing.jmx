        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /products/add - Create Product [${title}]">
          <stringProp name="HTTPSampler.path">${PRODUCTS_ENDPOINT}</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
