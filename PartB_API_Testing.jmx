        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor - Build Product Request Body from CSV" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
import groovy.json.JsonOutput

// Read CSV-populated JMeter variables
def title       = vars.get(&quot;title&quot;)?.trim()
def priceStr    = vars.get(&quot;price&quot;)?.trim()
def description = vars.get(&quot;description&quot;)?.trim()
def category    = vars.get(&quot;category&quot;)?.trim()

if (!title || title == &quot;title&quot;) {
    log.warn(&quot;[PreProcessor] Skipping empty/header CSV row&quot;)
    vars.put(&quot;SKIP_REQUEST&quot;, &quot;true&quot;)
    return
}
vars.put(&quot;SKIP_REQUEST&quot;, &quot;false&quot;)


def priceValue
try {
    priceValue = priceStr.toDouble()
} catch (Exception e) {
    log.error(&quot;[PreProcessor] Invalid price in CSV: &quot; + priceStr)
    vars.put(&quot;SKIP_REQUEST&quot;, &quot;true&quot;)
    return
}


def payload = [
    title      : title,
    price      : priceValue,
    description: description,
    category   : category,
    images     : [&quot;https://cdn.dummyjson.com/products/images/placeholder.png&quot;]
]

def requestBody = JsonOutput.toJson(payload)
vars.put(&quot;REQUEST_BODY&quot;, requestBody)


log.info(&quot;=== [Task 2 PreProcessor] ===&quot;)
log.info(&quot;CSV Row  -&gt; title: &quot; + title + &quot; | price: &quot; + priceStr + &quot; | category: &quot; + category)
log.info(&quot;Request Body: &quot; + requestBody)
            </stringProp>
          </JSR223PreProcessor>
          <hashTree/>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert 1: HTTP Status Code is 201 Created" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49587">201</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">FAIL: Expected HTTP 201 Created for product &quot;${title}&quot; but received a different status</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
          <JSONPathAssertion guiclass="JSONPathAssertionGui" testclass="JSONPathAssertion" testname="Assert 2: Response contains &apos;id&apos; field (product created)" enabled="true">
            <stringProp name="JSON_PATH">$.id</stringProp>
            <stringProp name="EXPECTED_VALUE"></stringProp>
            <boolProp name="JSONVALIDATION">false</boolProp>
            <boolProp name="EXPECT_NULL">false</boolProp>
            <boolProp name="INVERT">false</boolProp>
            <boolProp name="ISREGEX">false</boolProp>
            <stringProp name="Assertion.custom_message">FAIL: Response must contain &apos;id&apos; field indicating a product was created</stringProp>
          </JSONPathAssertion>
          <hashTree/>
          <JSONPathAssertion guiclass="JSONPathAssertionGui" testclass="JSONPathAssertion" testname="Assert 3: Response title matches CSV input [${title}]" enabled="true">
            <stringProp name="JSON_PATH">$.title</stringProp>
            <stringProp name="EXPECTED_VALUE">${title}</stringProp>
            <boolProp name="JSONVALIDATION">true</boolProp>
            <boolProp name="EXPECT_NULL">false</boolProp>
            <boolProp name="INVERT">false</boolProp>
            <boolProp name="ISREGEX">false</boolProp>
            <stringProp name="Assertion.custom_message">FAIL: Response title does not match CSV value &quot;${title}&quot;</stringProp>
          </JSONPathAssertion>
          <hashTree/>
          <JSONPathAssertion guiclass="JSONPathAssertionGui" testclass="JSONPathAssertion" testname="Assert 4: Response category matches CSV input [${category}]" enabled="true">
            <stringProp name="JSON_PATH">$.category</stringProp>
            <stringProp name="EXPECTED_VALUE">${category}</stringProp>
            <boolProp name="JSONVALIDATION">true</boolProp>
            <boolProp name="EXPECT_NULL">false</boolProp>
            <boolProp name="INVERT">false</boolProp>
            <boolProp name="ISREGEX">false</boolProp>
            <stringProp name="Assertion.custom_message">FAIL: Response category does not match CSV value &quot;${category}&quot;</stringProp>
          </JSONPathAssertion>
          <hashTree/>
          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="Assert 5: Response price matches CSV input (numeric comparison)" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
import groovy.json.JsonSlurper

def responseBody = prev.getResponseDataAsString()
if (!responseBody) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;Response body is empty — cannot validate price&quot;)
    return
}

def json = new JsonSlurper().parseText(responseBody)
def expectedPriceStr = vars.get(&quot;price&quot;)
def actualPrice      = json.price

if (expectedPriceStr == null || actualPrice == null) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;Price fields missing: expected=&quot; + expectedPriceStr + &quot;, actual=&quot; + actualPrice)
    return
}

def expectedPrice = expectedPriceStr.toDouble()
def actualPriceD  = (actualPrice instanceof Number) ? (actualPrice as double) : actualPrice.toString().toDouble()
def diff          = Math.abs(actualPriceD - expectedPrice)

if (diff &gt; 0.001) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;Price mismatch: expected=&quot; + expectedPrice + &quot;, actual=&quot; + actualPriceD)
} else {
    AssertionResult.setFailure(false)
    log.info(&quot;[Assert 5] Price PASSED: &quot; + actualPriceD + &quot; == expected &quot; + expectedPrice)
}
            </stringProp>
          </JSR223Assertion>
          <hashTree/>
          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion" testname="Assert 6: Response Time within ${RESPONSE_TIME_THRESHOLD_MS}ms SLA" enabled="true">
            <stringProp name="DurationAssertion.duration">${RESPONSE_TIME_THRESHOLD_MS}</stringProp>
          </DurationAssertion>
          <hashTree/>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert 7: Response body is a JSON object">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="2975">\{</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">FAIL: Response body is not a JSON object (expected to start with &apos;{&apos;)</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
          </ResponseAssertion>
          <hashTree/>
          <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="JSON Extractor - Capture Created Product ID">
            <stringProp name="JSONPostProcessor.referenceNames">CREATED_PRODUCT_ID</stringProp>
            <stringProp name="JSONPostProcessor.jsonPathExprs">$.id</stringProp>
            <stringProp name="JSONPostProcessor.match_numbers">0</stringProp>
            <stringProp name="JSONPostProcessor.defaultValues">ID_NOT_FOUND</stringProp>
          </JSONPostProcessor>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor - Log and Validate Product Response">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper

def responseCode = prev.getResponseCode()
def responseTime = prev.getTime()
def responseBody = prev.getResponseDataAsString()
def csvTitle     = vars.get(&quot;title&quot;)

log.info(&quot;=== [Task 2 PostProcessor] ===&quot;)
log.info(&quot;Product: &quot; + csvTitle + &quot; | HTTP: &quot; + responseCode + &quot; | Time: &quot; + responseTime + &quot;ms&quot;)

if ((responseCode == &quot;200&quot; || responseCode == &quot;201&quot;) &amp;&amp; responseBody) {
    def json = new JsonSlurper().parseText(responseBody)

    log.info(&quot;Created Product ID	: &quot; + json.id)
    log.info(&quot;Echoed Title 		: &quot; + json.title)
    log.info(&quot;Echoed Price         : &quot; + json.price)
    log.info(&quot;Echoed Category      : &quot; + json.category)
    log.info(&quot;Echoed Description   : &quot; + json.description)


    vars.put(&quot;LAST_CREATED_PRODUCT_ID&quot;, json.id?.toString() ?: &quot;N/A&quot;)

    // Validate price is returned as a Number type
    if (json.price instanceof Number) {
        log.info(&quot;Price type check PASSED: &quot; + json.price + &quot; is numeric&quot;)
    } else {
        log.warn(&quot;Price type check WARNING: returned as &quot; + json.price?.getClass()?.simpleName)
    }

    log.info(&quot;=== [Task 2 PostProcessor END] ===&quot;)
} else {
    log.error(&quot;[Task 2 PostProcessor] UNEXPECTED status for product &apos;&quot; + csvTitle + &quot;&apos;: HTTP &quot; + responseCode + &quot; (expected 200 or 201)&quot;)
    log.error(&quot;Response body: &quot; + responseBody)
}
            </stringProp>
          </JSR223PostProcessor>
