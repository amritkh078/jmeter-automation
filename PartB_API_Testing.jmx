          <DurationAssertion guiclass="DurationAssertionGui" testclass="DurationAssertion" testname="Assert 6: Response Time within ${RESPONSE_TIME_THRESHOLD_MS}ms SLA">
            <stringProp name="DurationAssertion.duration">${RESPONSE_TIME_THRESHOLD_MS}</stringProp>
