          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor - User Data Transformation (Groovy)">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
import groovy.json.JsonSlurper
import groovy.json.JsonOutput
import java.time.LocalDateTime
import java.time.format.DateTimeFormatter

def responseCode = prev.getResponseCode()
def responseBody = prev.getResponseDataAsString()

if (responseCode != &quot;200&quot; || !responseBody) {
    log.error(&quot;[Task 3 PostProcessor] Cannot transform: HTTP &quot; + responseCode)
    vars.put(&quot;TRANSFORMATION_STATUS&quot;, &quot;FAILED&quot;)
    return
}

// Parse full response
def data     = new JsonSlurper().parseText(responseBody)
def allUsers = data.users

def users      = allUsers.take(10)
def totalUsers = users.size()


def totalAge = 0
users.each { u -&gt; totalAge += (u.age ?: 0) }
def avgAge = Math.round((totalAge / totalUsers) * 10) / 10.0

def genderDist = [:]
users.each { u -&gt;
    def g = u.gender?.toLowerCase() ?: &quot;unknown&quot;
    genderDist[g] = (genderDist.containsKey(g) ? genderDist[g] : 0) + 1
}
def deptDist = [:]
users.each { u -&gt;
    def dept = u.company?.department ?: &quot;Unknown&quot;
    deptDist[dept] = (deptDist.containsKey(dept) ? deptDist[dept] : 0) + 1
}

def transformedUsers = users.collect { u -&gt;
    [
        id        : u.id,
        fullName  : (u.firstName ?: &quot;&quot;) + &quot; &quot; + (u.lastName ?: &quot;&quot;),
        email     : u.email,
        age       : u.age,
        gender    : u.gender,
        city      : u.address?.city,
        state     : u.address?.state,
        country   : u.address?.country,
        company   : u.company?.name,
        department: u.company?.department,
        jobTitle  : u.company?.title
    ]
}

def transformedAt = LocalDateTime.now().format(DateTimeFormatter.ISO_LOCAL_DATE_TIME)

def output = [
    metadata: [
        totalUsers            : totalUsers,
        averageAge            : avgAge,
        genderDistribution    : genderDist,
        departmentDistribution: deptDist,
        transformedAt         : transformedAt
    ],
    users: transformedUsers
]


def outputDirAbs = vars.get(&quot;OUTPUT_DIR_ABS&quot;) ?: vars.get(&quot;OUTPUT_DIR&quot;) ?: &quot;./output&quot;
def outputFile   = new File(outputDirAbs + &quot;/users_transformed.json&quot;)
outputFile.parentFile?.mkdirs()
outputFile.text = JsonOutput.prettyPrint(JsonOutput.toJson(output))

vars.put(&quot;TRANSFORMATION_STATUS&quot;,    &quot;SUCCESS&quot;)
vars.put(&quot;TOTAL_USERS_PROCESSED&quot;,    totalUsers.toString())
vars.put(&quot;AVERAGE_AGE&quot;,              avgAge.toString())
vars.put(&quot;OUTPUT_FILE_PATH&quot;,         outputFile.absolutePath)
vars.put(&quot;GENDER_DISTRIBUTION&quot;,      genderDist.toString())
vars.put(&quot;DEPT_DISTRIBUTION&quot;,        deptDist.toString())

def sep = &quot;=&quot; * 60


log.info(sep)
log.info(&quot;USER DATA TRANSFORMATION COMPLETED&quot;)
log.info(sep)
log.info(&quot;Total Users Processed: &quot; + totalUsers)
log.info(&quot;Average Age: &quot; + avgAge + &quot; years&quot;)
log.info(&quot;Gender Distribution: &quot; + genderDist)
log.info(&quot;Department Distribution: &quot; + deptDist)
log.info(&quot;Output saved to: &quot; + outputFile.absolutePath)
log.info(sep)

println(sep)
println(&quot;USER DATA TRANSFORMATION COMPLETED&quot;)
println(sep)
println(&quot;Total Users Processed: &quot; + totalUsers)
println(&quot;Average Age: &quot; + avgAge + &quot; years&quot;)
println(&quot;Gender Distribution: &quot; + genderDist)
println(&quot;Department Distribution: &quot; + deptDist)
println(&quot;Output saved to: &quot; + outputFile.absolutePath)
println(sep)
            </stringProp>
          </JSR223PostProcessor>
